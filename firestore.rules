rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'fsferdows04@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collection Validations ---

    function isValidUser(data) {
      return data.email is string && 
             data.displayName is string &&
             data.role in ['user', 'admin'] &&
             data.createdAt != null;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.images is list && data.images.size() > 0 &&
             data.inventoryCount is number;
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.items is list && data.items.size() > 0;
    }

    function isValidReview(data) {
      return data.productId is string &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000;
    }

    // --- Rules ---

    // 1. Users Profile
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if (isOwner(userId) || isAdmin()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'address', 'role']) &&
                      (incoming().role == existing().role || isAdmin());
    }

    // 2. Products
    match /products/{productId} {
      allow get: if true;
      allow list: if true; // Public listings are acceptable for product discovery
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // 3. Orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isEmailVerified() && isValidOrder(incoming()) && 
                      incoming().status == 'pending' &&
                      incoming().createdAt == request.time;
      
      allow update: if isAdmin() || 
                      (isOwner(existing().userId) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                       incoming().status == 'cancelled' && 
                       existing().status == 'pending');
    }

    // 4. Reviews
    match /reviews/{reviewId} {
      allow get: if true;
      allow list: if true; // Reviews are public; usually queried by productId
      
      allow create: if isSignedIn() && isEmailVerified() && 
                    isValidReview(incoming()) && 
                    incoming().createdAt == request.time;
      
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // 5. RBAC
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
